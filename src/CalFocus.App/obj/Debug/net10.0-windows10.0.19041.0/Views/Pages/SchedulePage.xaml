<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="CalFocus.App.Views.Pages.SchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">
    <Grid Padding="16,10,16,16">
        <Border CornerRadius="22"
                BorderThickness="1"
                BorderBrush="#33FFFFFF"
                Background="#2A101827"
                Padding="16">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.35*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:ConnectionId='2' x:Name="ClockText"
                               Grid.Row="0"
                               FontSize="48"
                               FontWeight="SemiBold"
                               Text="00:00:00" />

                    <Border Grid.Row="2"
                            CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="#2DFFFFFF"
                            Background="#1F1B2436"
                            Padding="14">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.8" Text="天气（预留 API）" />
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="20℃  多云" />
                            <TextBlock FontSize="12" Opacity="0.75" Text="Weather API Endpoint: /api/weather/today" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="#2DFFFFFF"
                            Background="#1B213346"
                            Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="计划表" />
                            <TextBlock Opacity="0.85" Text="• 本周发布 v0.1" />
                            <TextBlock Opacity="0.85" Text="• 完成托盘 + 小组件收尾" />
                            <TextBlock Opacity="0.85" Text="• 视觉稿第一轮评审" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="#2DFFFFFF"
                            Background="#202A2040"
                            Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="提醒" />
                            <TextBlock Opacity="0.85" Text="• 16:00 提交迭代说明" />
                            <TextBlock Opacity="0.85" Text="• 18:30 运动 30 分钟" />
                            <TextBlock Opacity="0.85" Text="• 22:30 明日计划整理" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Border CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="#2DFFFFFF"
                            Background="#23283945"
                            Padding="14">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="日程表" />

                            <StackPanel Grid.Row="1" Spacing="10">
                                <Border CornerRadius="12" Background="#2A3A4C66" Padding="12">
                                    <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="项目站会" />
                                        <TextBlock FontSize="12" Opacity="0.78" Text="2026-03-26  09:30 - 10:00" />
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="12" Background="#2A425062" Padding="12">
                                    <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="交互评审" />
                                        <TextBlock FontSize="12" Opacity="0.78" Text="2026-03-26  14:00 - 15:00" />
                                    </StackPanel>
                                </Border>

                                <Border CornerRadius="12" Background="#2A4D4A60" Padding="12">
                                    <StackPanel VerticalAlignment="Bottom" Spacing="4">
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="每日复盘" />
                                        <TextBlock FontSize="12" Opacity="0.78" Text="2026-03-26  17:30 - 18:00" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>

