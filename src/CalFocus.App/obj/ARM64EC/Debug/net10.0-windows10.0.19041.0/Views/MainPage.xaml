<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="CalFocus.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <NavigationView x:ConnectionId='2' x:Name="RootNav"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                                                             >
            <NavigationView.MenuItems>
                <NavigationViewItem Content="日历日程" Tag="schedule" Icon="Calendar" />
                <NavigationViewItem Content="提醒事项" Tag="reminder" Icon="Important" />
                <NavigationViewItem Content="小组件中心" Tag="widgets" Icon="AllApps" />
                <NavigationViewItem Content="主题与外观" Tag="theme" Icon="Highlight" />
            </NavigationView.MenuItems>

            <Frame x:ConnectionId='3' x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Page>

