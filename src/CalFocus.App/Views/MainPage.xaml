<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="CalFocus.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <NavigationView x:Name="RootNav"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        IsTitleBarAutoPaddingEnabled="False"
                        AlwaysShowHeader="False"
                        SelectionChanged="OnSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="主页" Tag="home" Icon="Home" />
                <NavigationViewItem Content="日历日程" Tag="calendar" Icon="Calendar" />
                <NavigationViewItem Content="待办提醒" Tag="todoreminder" Icon="Important" />
                <NavigationViewItem Content="小组件" Tag="widgets" Icon="AllApps" />
                <NavigationViewItem Content="主题外观" Tag="theme" Icon="Highlight" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Page>
