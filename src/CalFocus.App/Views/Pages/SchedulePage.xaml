<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="CalFocus.App.Views.Pages.SchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">
    <Grid Style="{StaticResource PageRootGridStyle}" Padding="16">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="1">
                        <TextBlock Text="当前时间" Style="{StaticResource SectionHintTextStyle}" />
                        <TextBlock x:Name="CurrentTimeText" FontSize="46" FontWeight="SemiBold" Foreground="{ThemeResource AppBrandBrush}" Text="14:30:45" />
                        <TextBlock x:Name="CurrentDateText" FontSize="13" Foreground="{ThemeResource AppMutedBrush}" Text="2026年03月29日 星期日" />
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}" Padding="10,8">
                        <StackPanel Spacing="1">
                            <TextBlock Text="天气（API 预留）" FontSize="12" Foreground="{ThemeResource AppMutedBrush}" />
                            <TextBlock x:Name="WeatherTempText" FontSize="26" FontWeight="SemiBold" Foreground="{ThemeResource AppTextBrush}" Text="--°C" />
                            <TextBlock x:Name="WeatherStatusText" FontSize="12" Foreground="{ThemeResource AppMutedBrush}" Text="等待天气服务接入" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="未来提醒" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource AppTitleBrush}" />
                            <TextBlock x:Name="ReminderCountText" FontSize="12" Foreground="{ThemeResource AppMutedBrush}" Text="共 0 项" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="+" Click="OnAddReminderClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                    </Grid>

                    <ListView Grid.Row="3"
                              x:Name="ReminderListHome"
                              IsItemClickEnabled="False"
                              SelectionMode="None"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource AppTodayHighlightBrush}"
                                        BorderBrush="{ThemeResource AppBrandBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,3">
                                    <StackPanel Spacing="0">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AppTextBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{ThemeResource AppMutedBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}" Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="2">
                            <TextBlock Text="未来日程" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock x:Name="ScheduleSummaryText" FontSize="12" Foreground="{ThemeResource AppMutedBrush}" Text="共 0 条" />
                        </StackPanel>

                        <Button Grid.Column="1" Content="+" Click="OnAddScheduleClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                    </Grid>

                    <ListView Grid.Row="1"
                              x:Name="AllScheduleList"
                              IsItemClickEnabled="False"
                              SelectionMode="None"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource AppCardBrush}"
                                        BorderBrush="{ThemeResource AppBrandBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,3">
                                    <StackPanel Spacing="0">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AppTextBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{ThemeResource AppMutedBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}" Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="未来计划" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock x:Name="TodoCountText" Style="{StaticResource SectionHintTextStyle}" Text="共 0 项" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="+" Click="OnAddTodoClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                    </Grid>

                    <ListView Grid.Row="1"
                              x:Name="TodoListHome"
                              IsItemClickEnabled="False"
                              SelectionMode="None"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource AppCardBrush}"
                                        BorderBrush="{ThemeResource AppBrandBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6,3">
                                    <StackPanel Spacing="0">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AppTextBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{ThemeResource AppMutedBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
