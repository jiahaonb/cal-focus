<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="CalFocus.App.Views.Pages.CalendarSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="{ThemeResource AppBackgroundBrush}">

    <Page.Resources>
        <DataTemplate x:Key="DayCellTemplate">
            <Border
                x:Name="DayCardBorder"
                Margin="3"
                Background="{Binding BackgroundBrush}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="{Binding BorderThickness}"
                CornerRadius="12"
                Padding="6,4"
                Tag="{Binding Date}"
                Tapped="OnDayCardTapped"
                DoubleTapped="OnDayCardDoubleTapped"
                PointerEntered="OnDayCardPointerEntered"
                PointerExited="OnDayCardPointerExited">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                        <Border x:Name="DayNumberBadgeBorder"
                            Grid.Row="0"
                            Background="{Binding DayBadgeBackground}"
                            CornerRadius="6"
                            HorizontalAlignment="Left"
                            Padding="8,3">
                        <TextBlock Text="{Binding DayNumber}" Foreground="{Binding DayForeground}" FontSize="14" FontWeight="SemiBold" />
                    </Border>

                    <Border Grid.Row="1"
                            Background="Transparent" />

                    <TextBlock Grid.Row="2"
                               Text="{Binding ScheduleSummary}"
                               Visibility="{Binding ScheduleSummaryVisibility}"
                               Foreground="{ThemeResource AppMutedBrush}"
                               FontSize="11"
                               HorizontalAlignment="Right"
                               Margin="0,0,2,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ScheduleDetailTemplate">
            <Border Style="{StaticResource SurfaceCardStyle}" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="0">
                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AppTextBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding DisplayTime}" FontSize="11" Foreground="{ThemeResource AppMutedBrush}" />
                    </StackPanel>

                    <Button Grid.Column="1" Content="编辑" Tag="{Binding Id}" Click="OnScheduleClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ProductivityDetailTemplate">
            <Border Style="{StaticResource SurfaceCardStyle}" Padding="8,6">
                <StackPanel Spacing="0">
                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AppTextBrush}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding DisplaySummary}" FontSize="11" Foreground="{ThemeResource AppMutedBrush}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Style="{StaticResource PageRootGridStyle}" Padding="16" RowSpacing="12" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="DetailColumn" Width="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="3">
                <TextBlock Text="日历日程" Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="单击日期选中，双击数字弹出详情卡片，双击日期空白区快速新建日程" Style="{StaticResource SectionHintTextStyle}" />
            </StackPanel>

            <Button Grid.Column="1" Content="新增日程" Click="OnAddScheduleClick" Style="{StaticResource PrimaryActionButtonStyle}" />
        </Grid>

        <Border x:Name="CalendarBorder" Grid.Row="1" Grid.Column="0" Style="{StaticResource GlassCardStyle}" Padding="12" Tapped="OnCalendarBorderTapped">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ComboBox x:Name="YearCombo" Width="96" SelectionChanged="OnYearMonthSelectionChanged" />
                        <ComboBox x:Name="MonthCombo" Width="80" SelectionChanged="OnYearMonthSelectionChanged" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Click="OnPrevMonthClick" Style="{StaticResource SecondaryActionButtonStyle}">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Click="OnNextMonthClick" Style="{StaticResource SecondaryActionButtonStyle}">
                            <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Click="OnTodayClick" Content="今天" Style="{StaticResource SecondaryActionButtonStyle}" />
                        <Button Click="OnShowDetailsClick" Content="详情" Style="{StaticResource SecondaryActionButtonStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="周日" HorizontalAlignment="Center" Foreground="{ThemeResource AppMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="周一" HorizontalAlignment="Center" Foreground="{ThemeResource AppMutedBrush}" />
                    <TextBlock Grid.Column="2" Text="周二" HorizontalAlignment="Center" Foreground="{ThemeResource AppMutedBrush}" />
                    <TextBlock Grid.Column="3" Text="周三" HorizontalAlignment="Center" Foreground="{ThemeResource AppMutedBrush}" />
                    <TextBlock Grid.Column="4" Text="周四" HorizontalAlignment="Center" Foreground="{ThemeResource AppMutedBrush}" />
                    <TextBlock Grid.Column="5" Text="周五" HorizontalAlignment="Center" Foreground="{ThemeResource AppMutedBrush}" />
                    <TextBlock Grid.Column="6" Text="周六" HorizontalAlignment="Center" Foreground="{ThemeResource AppMutedBrush}" />
                </Grid>

                <Grid x:Name="DaysGrid" Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="DetailsBorder" Grid.Row="1" Grid.Column="1" Style="{StaticResource GlassCardStyle}" Padding="12" Visibility="Collapsed">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="SelectedDateTitleText" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource AppBrandBrush}" />
                        <TextBlock x:Name="SelectedDateHintText" Style="{StaticResource SectionHintTextStyle}" Text="当日日程、提醒、待办会按时间顺序展示" />
                    </StackPanel>

                    <Button Grid.Column="1" Content="收起" Click="OnHideDetailsClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource SurfaceCardStyle}" Padding="10">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="日程" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource AppTitleBrush}" />
                                        <TextBlock x:Name="ScheduleDetailCountText" Foreground="{ThemeResource AppMutedBrush}" />
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="+" Click="OnAddScheduleForSelectedDateClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                                </Grid>

                                <Grid Grid.Row="1">
                                    <ListView x:Name="DayScheduleList"
                                              IsItemClickEnabled="False"
                                              SelectionMode="None"
                                              ItemTemplate="{StaticResource ScheduleDetailTemplate}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollMode="Disabled">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,0,6" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>

                                    <TextBlock x:Name="EmptyScheduleHintText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource AppMutedBrush}"
                                               Text="当天暂无日程"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SurfaceCardStyle}" Padding="10">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="提醒" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource AppTitleBrush}" />
                                        <TextBlock x:Name="ReminderDetailCountText" Foreground="{ThemeResource AppMutedBrush}" />
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="+" Click="OnAddReminderForSelectedDateClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                                </Grid>

                                <Grid Grid.Row="1">
                                    <ListView x:Name="DayReminderList"
                                              IsItemClickEnabled="False"
                                              SelectionMode="None"
                                              ItemTemplate="{StaticResource ProductivityDetailTemplate}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollMode="Disabled">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,0,6" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>

                                    <TextBlock x:Name="EmptyReminderHintText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource AppMutedBrush}"
                                               Text="当天暂无提醒"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SurfaceCardStyle}" Padding="10">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="待办" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource AppTitleBrush}" />
                                        <TextBlock x:Name="TodoDetailCountText" Foreground="{ThemeResource AppMutedBrush}" />
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="+" Click="OnAddTodoForSelectedDateClick" Style="{StaticResource SecondaryActionButtonStyle}" />
                                </Grid>

                                <Grid Grid.Row="1">
                                    <ListView x:Name="DayTodoList"
                                              IsItemClickEnabled="False"
                                              SelectionMode="None"
                                              ItemTemplate="{StaticResource ProductivityDetailTemplate}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollMode="Disabled">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,0,6" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>

                                    <TextBlock x:Name="EmptyTodoHintText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource AppMutedBrush}"
                                               Text="当天暂无待办"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
