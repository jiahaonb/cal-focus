<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="CalFocus.App.Views.Pages.HelpAboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled">
        <Grid Padding="24,20,24,28"
              HorizontalAlignment="Center"
              MaxWidth="1120">
            <StackPanel Spacing="20">
                <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="帮助关于" />
                <TextBlock Style="{StaticResource SectionHintTextStyle}" Text="快速了解 CalFocus 的核心操作与功能说明。" />
                </StackPanel>

                <Border Style="{StaticResource GlassCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppTitleBrush}" Text="使用说明" />
                        <TextBlock Text="1. 主页提供时间、近期日程、待办与提醒总览。" TextWrapping="Wrap" Foreground="{ThemeResource AppTextBrush}" />
                        <TextBlock Text="2. 日历页双击日期数字可弹出详情卡片，双击日期空白区可快速新建日程。" TextWrapping="Wrap" Foreground="{ThemeResource AppTextBrush}" />
                        <TextBlock Text="3. 日历头部的“详情”按钮可在右侧固定展开当日详情。" TextWrapping="Wrap" Foreground="{ThemeResource AppTextBrush}" />
                        <TextBlock Text="4. 小组件支持时钟、日程和番茄钟，右上角三点菜单可调整大小与颜色。" TextWrapping="Wrap" Foreground="{ThemeResource AppTextBrush}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppTitleBrush}" Text="基本操作提示" />
                        <TextBlock Text="1. 设置页可调整主题色、玻璃效果、阴影和性能模式。" TextWrapping="Wrap" Foreground="{ThemeResource AppTextBrush}" />
                        <TextBlock Text="2. 待办项支持 DDL，提醒项支持事件时间与提醒时间。" TextWrapping="Wrap" Foreground="{ThemeResource AppTextBrush}" />
                        <TextBlock Text="3. 番茄钟默认 15 分钟，可直接输入分钟并开始/暂停。" TextWrapping="Wrap" Foreground="{ThemeResource AppTextBrush}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AppTitleBrush}" Text="关于" />
                            <TextBlock Foreground="{ThemeResource AppTextBrush}" Text="CalFocus - Windows 桌面日历与效率工具" />
                            <TextBlock Foreground="{ThemeResource AppMutedBrush}" Text="统一视觉 · 高级玻璃质感 · 稳定交互" />
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource SoftTagBorderStyle}" VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold" Foreground="{ThemeResource AppBrandBrush}" Text="v1.0" />
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
