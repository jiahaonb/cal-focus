<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="CalFocus.App.Views.Pages.WidgetCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">
    <Grid Padding="24">
        <StackPanel Spacing="14" MaxWidth="560">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="小组件中心" />
            <TextBlock Opacity="0.8" Text="当前阶段支持最小版桌面时钟/日程组件，可进行添加、删除与复制。" />

            <Border Padding="16" CornerRadius="12" BorderThickness="1" BorderBrush="#33FFFFFF" Background="#22000000">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="组件操作" />
                    <TextBlock x:Name="WidgetCountText" Text="当前数量：0" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="添加时钟组件" Click="OnAddClockWidgetClick" />
                        <Button Content="添加日程组件" Click="OnAddScheduleWidgetClick" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="复制最后一个组件" Click="OnCopyLastWidgetClick" />
                        <Button Content="删除最后一个组件" Click="OnRemoveLastWidgetClick" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
